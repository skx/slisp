;;; NASM assembly file generated by slisp.

;; Compile this with nasm and link like so:
;;
;;    nasm -f elf64 example.s
;;    ld -o example example.o
;;

;; contents
;;
;; 1. macros
;; 2. User-defined functions (defuns)
;; 3. User-defined lambdas
;; 4. entry-point
;; 5. stdlib
;; 6. string-table
;;


;;; 1. macros
;;
;; We use the lower three bits of values to denote their type,
;; string, int, char, lambda, cons, etc.
;;
;; These macros are to be used to tag a register with a given
;; type, or get the type for processing and testing.
;;

; tag a register as an integer
%macro TAG_INTEGER_REG 1
    sal %1, 3
%endmacro

; tag a register as a string
%macro TAG_STRING_REG 1
    sal %1, 3
    or %1, TAG_ID_STRING
%endmacro

; tag a register as a cons pair
%macro TAG_CONS_REG 1
    sal %1, 3
    or %1, TAG_ID_CONS
%endmacro

; tag a register as a lambda
%macro TAG_LAMBDA_REG 1
    sal %1, 3
    or %1, TAG_ID_LAMBDA
%endmacro


; tag a register as a character
%macro TAG_CHAR_REG 1
    sal %1, 3
    or %1, TAG_ID_CHAR
%endmacro

; tag a register as NIL
%macro TAG_NIL_REG 1
    sal %1, 3
    or %1, TAG_ID_NIL
%endmacro

; remove the tag-bits from a register.
; just shift right 3 bits.
%macro UNTAG_REG 1
    sar %1, 3
%endmacro

; get the tag bits for the given register.
%macro GET_TAG_BITS 1
    and %1, 7
%endmacro

; The value of the tag-bits we use to denote types
TAG_ID_INTEGER equ 0b000
TAG_ID_STRING  equ 0b001
TAG_ID_CONS    equ 0b010
TAG_ID_LAMBDA  equ 0b011
TAG_ID_CHAR    equ 0b100
TAG_ID_NIL     equ 0b111


;;; 2. User-defined functions (defuns)
{{ .Defuns }}

;;; 3. User-defined lambdas
{{ .Lambdas }}

;;; 4. entry-point
global _start
section .text

_start:
    mov rax, heap        ; setup our heap pointer
    mov [heap_ptr], rax  ; cons cells are heap-allocated

    call fn_main
    mov rdi, rax         ; exit code is the last expression
    UNTAG_REG rdi
    mov rax, 60
    syscall



;;; 5. stdlib
section .text

;; Is the given value an integer?
intp:
    mov rax, rdi
    GET_TAG_BITS rax
    cmp rax, TAG_ID_INTEGER
    jnz .nil
    mov rax, 1
    TAG_INTEGER_REG rax
    ret
.nil:
    xor rax, rax
    TAG_NIL_REG rax
    ret

;; Is the given value an character?
charp:
    mov rax, rdi
    GET_TAG_BITS rax
    cmp rax, TAG_ID_CHAR
    jnz .nil
    mov rax, 1
    TAG_INTEGER_REG rax
    ret
.nil:
    xor rax, rax
    TAG_NIL_REG rax
    ret

;; Is the given value a string?
strp:
    mov rax, rdi
    GET_TAG_BITS rax
    cmp rax, TAG_ID_STRING
    jnz .nil
    mov rax, 1
    TAG_INTEGER_REG rax
    ret
.nil:
    xor rax, rax
    TAG_NIL_REG rax
    ret

;; Is the given value a cons?
consp:
    mov rax, rdi
    GET_TAG_BITS rax
    cmp rax, TAG_ID_CONS
    jnz .nil
    mov rax, 1
    TAG_INTEGER_REG rax
    ret
.nil:
    xor rax, rax
    TAG_NIL_REG rax
    ret

;; is the given value a lambda?
lambdap:
    mov rax, rdi
    GET_TAG_BITS rax
    cmp rax, TAG_ID_LAMBDA
    jnz .nil
    mov rax, 1
    TAG_INTEGER_REG rax
    ret
.nil:
    xor rax, rax
    TAG_NIL_REG rax
    ret

;; Is the given value nil?
nilp:
    mov rax, rdi
    GET_TAG_BITS rax
    cmp rax, TAG_ID_NIL
    jnz .nil
    mov rax, 1
    TAG_INTEGER_REG rax
    ret
.nil:
    xor rax, rax
    TAG_NIL_REG rax
    ret

;; +
integer_plus:
   UNTAG_REG rdi
   UNTAG_REG rsi
   mov rax, rdi
   add rax, rsi
   TAG_INTEGER_REG rax
   ret

;; -
integer_minus:
   UNTAG_REG rdi
   UNTAG_REG rsi
   sub rdi, rsi
   mov rax, rdi
   TAG_INTEGER_REG rax
   ret

;; /
integer_divide:
   UNTAG_REG rdi
   UNTAG_REG rsi

   mov rax, rdi
   cqo
   idiv rsi

   TAG_INTEGER_REG rax
   ret

;; %
integer_modulus:
   UNTAG_REG rdi
   UNTAG_REG rsi

   mov rax, rdi
   cqo
   idiv rsi

   mov rax, rdx
   TAG_INTEGER_REG rax
   ret

;; *
integer_multiply:
   UNTAG_REG rdi
   UNTAG_REG rsi
   mov rax, rdi
   mov rbx, rsi
   imul rbx, rax
   mov rax, rbx
   TAG_INTEGER_REG rax
   ret


;; NOT
;; a nil becomes 1.
;; anything else becomes nil
fn_not:
    mov rax, rdi
    GET_TAG_BITS rax
    cmp rax, TAG_ID_NIL
    jz .nil
    xor rax, rax
    TAG_NIL_REG rax
    ret
.nil:
    mov rax, 1
    TAG_INTEGER_REG rax
    ret

;; =
equals:
    mov rax, rdi
    mov rbx, rsi
    GET_TAG_BITS rbx     ; type of arg
    GET_TAG_BITS rax     ; type of arg
    cmp rax, rbx
    jnz .nil         ; different types?  Then not equal

    ; If one of the types is a string then we know both are.
    ; RSI/RDI will still have their original values so we can
    ; call strcmp.  If the value is 0 we know they are equal
    cmp rax, TAG_ID_STRING
    jnz .not_strings
    call fn_strcmp
    UNTAG_REG rax
    cmp rax, 0
    jz .equal
    jmp .nil

.not_strings:
    cmp rdi, rsi     ; same types, so compare the values directly
    jnz .nil
.equal:
    mov rax, 1
    TAG_INTEGER_REG rax
    ret
.nil:
    xor rax, rax
    TAG_NIL_REG rax
    ret


;; <=
lt_equals:
    UNTAG_REG rdi
    UNTAG_REG rsi
    cmp rdi, rsi
    jle .true
    xor rax, rax
    TAG_NIL_REG rax
    ret
.true:
    mov rax, 1
    TAG_INTEGER_REG rax
    ret

;; >=
gt_equals:
    UNTAG_REG rdi
    UNTAG_REG rsi
    cmp rdi, rsi
    jge .true
    xor rax, rax
    TAG_NIL_REG rax
    ret
.true:
    mov rax, 1
    TAG_INTEGER_REG rax
    ret

;; <
lt:
    UNTAG_REG rdi
    UNTAG_REG rsi
    cmp rdi, rsi
    jl .true
    xor rax, rax
    TAG_NIL_REG rax
    ret
.true:
    mov rax, 1
    TAG_INTEGER_REG rax
    ret

;; >
gt:
    UNTAG_REG rdi
    UNTAG_REG rsi
    cmp rdi, rsi
    jg .true
    xor rax, rax
    TAG_NIL_REG rax
    ret
.true:
    mov rax, 1
    TAG_INTEGER_REG rax
    ret

;; Print an integer
fn_printint:
    push rbp
    mov rbp, rsp
    sub rsp, 64
    UNTAG_REG rax

    mov r8, 0            ; remember sign
    test rax, rax
    jge .positive
    neg rax
    mov r8, 1
.positive:
    lea rsi, [rsp+63]
    mov byte [rsi], 0
    xor rcx, rcx

.convert:
    xor rdx, rdx
    mov rbx, 10
    div rbx
    add dl, '0'
    dec rsi
    mov [rsi], dl
    inc rcx
    test rax, rax
    jnz .convert

    ; prepend minus sign if needed
    cmp r8, 0
    je .write
    dec rsi
    mov byte [rsi], '-'
    inc rcx
.write:
    mov rax, 1
    mov rdi, 1
    mov rdx, rcx
    syscall
    leave
    ret


;; terminate execution with the given exit-code
fn_exit:
    UNTAG_REG rdi
    mov rax, 60     ; sys_exit
    syscall
    ret


;; print a newline.
fn_newline:
    mov rax, 1      ; SYS_write
    mov rdi, 1      ; stdout
    mov rsi, newline_str
    mov rdx, 1
    syscall
    ret

;; Write the given ASCII character to stdout
fn_putc:
    mov rax, rdi
    UNTAG_REG rax
    mov [putc_buffer],  al  ; store character
    mov rax, 1      ; SYS_write
    mov rdi, 1      ; stdout
    mov rsi, putc_buffer
    mov rdx, 1
    syscall
    ret

;; Print the given string.
fn_printstr:
    UNTAG_REG rdi
    push rdi
    mov rdx, 0                ; length counter
.printstr_len_loop:
    cmp byte [rdi + rdx], 0
    je .printstr_found_len
    inc rdx
    jmp .printstr_len_loop
.printstr_found_len:
    pop rsi
    mov rax, 1      ; write
    mov rdi, 1      ; stdout
    syscall

    ret


;; chr - convert an integer to a character
fn_chr:
    mov rbx, rdi
    GET_TAG_BITS rbx
    cmp rbx, TAG_ID_INTEGER
    jne type_error
    UNTAG_REG rdi
    mov rax, rdi
    and rax, 0xFF        ; Only 0-255 is ASCII
    TAG_CHAR_REG rax
    ret


;; ord - convert a character to an integer.
fn_ord:
    mov rbx, rdi
    GET_TAG_BITS rbx
    cmp rbx, TAG_ID_CHAR
    jne type_error
    UNTAG_REG rdi
    mov rax, rdi
    TAG_INTEGER_REG rax
    ret

;; Allocate space for a new cons cell, return it in RAX.
;;
;; 16-bytes; first has the CAR, second the CDR.
fn_cons:
    mov rax, [heap_ptr]      ; get the value of the heap pointer
    add qword [heap_ptr], 16 ; bump it by 2x ptrs
    mov [rax], rdi           ; store first item
    mov [rax+8], rsi         ; second item
    TAG_CONS_REG rax         ; return the tagged allocation
    ret

;; Get the first item in the cons cell.
fn_car:
    mov rbx, rdi
    GET_TAG_BITS rbx
    cmp rbx, TAG_ID_CONS
    jne type_error
    UNTAG_REG rdi
    mov rax, [rdi]
    ret

;; Get the second item in the cons cell.
fn_cdr:
    mov rbx, rdi
    GET_TAG_BITS rbx
    cmp rbx, TAG_ID_CONS
    jne type_error
    UNTAG_REG rdi
    mov rax, [rdi + 8]
    ret

type_error:
    jmp fn_exit


;; Explode a string to a list of characters.
;; find the length and work backwards.
;; This is one of our more complex routines and yet it worked first time :D
fn_explode:
    mov rbx, rdi
    GET_TAG_BITS rbx
    cmp rbx, TAG_ID_STRING
    jne type_error

    UNTAG_REG rdi
    mov rsi, rdi
.find_end:
    cmp byte [rsi], 0
    je .found_end
    inc rsi
    jmp .find_end
.found_end:
    xor rax, rax
    TAG_NIL_REG rax
.loop:
    ; reached beginning?
    cmp rsi, rdi
    je .done
    dec rsi
    movzx rcx, byte [rsi]
    mov rdx, rcx
    TAG_CHAR_REG rdx
    mov r8, [heap_ptr]
    add qword [heap_ptr], 16
    mov [r8], rdx
    mov [r8+8], rax
    mov rax, r8
    TAG_CONS_REG rax
    jmp .loop
.done:
    ret


;; join a character list to a string
fn_implode:
    mov rbx,rdi
    xor rcx,rcx

.count:
    mov rax,rbx
    GET_TAG_BITS rax
    cmp rax,TAG_ID_NIL
    je .have_len

    ; verify cons
    mov rax,rbx
    GET_TAG_BITS rax
    cmp rax,TAG_ID_CONS
    jne type_error
    inc rcx
    mov rax,rbx
    UNTAG_REG rax
    mov rbx,[rax+8]
    jmp .count

.have_len:
    mov rax,[heap_ptr]
    mov rdx,rcx
    inc rdx
    add [heap_ptr],rdx
    mov r8,rax

    mov rbx,rdi
    xor rcx,rcx
.copy:
    mov rax,rbx
    GET_TAG_BITS rax
    cmp rax,TAG_ID_NIL
    je .finish

    mov rax,rbx
    UNTAG_REG rax
    mov rdx,[rax]
    ; verify char
    mov r9,rdx
    GET_TAG_BITS r9
    cmp r9,TAG_ID_CHAR
    jne type_error
    UNTAG_REG rdx
    mov [r8+rcx],dl
    inc rcx
    mov rbx,[rax+8]
    jmp .copy
.finish:
    mov byte [r8+rcx],0
    mov rax,r8
    TAG_STRING_REG rax
    ret


;; Find the length of the given string.
fn_strlen:
    mov rbx, rdi
    GET_TAG_BITS rbx
    cmp rbx, TAG_ID_STRING
    jne type_error

    UNTAG_REG rdi
    xor rax, rax
.find:
    cmp byte [rdi], 0
    je .found_end
    inc rdi
    inc rax
    jmp .find
.found_end:
    TAG_INTEGER_REG rax
    ret

;; Compare the two specified strings.
fn_strcmp:
    mov rbx, rdi             ; type-check arg1
    GET_TAG_BITS rbx
    cmp rbx, TAG_ID_STRING
    jne type_error
    mov rbx, rsi             ; type-check arg2
    GET_TAG_BITS rbx
    cmp rbx, TAG_ID_STRING
    jne type_error

    UNTAG_REG rdi
    UNTAG_REG rsi

.strcmp_next_char:
    mov al, byte [rdi]
    cmp al, byte [rsi]
    jne .strcmp_diff
    test al, al
    je .strcmp_done
    inc rdi
    inc rsi
    jmp .strcmp_next_char
.strcmp_diff:
    movzx rdx, byte [rsi]
    sub al, dl
.strcmp_done:
    movsx rax, al            ; Truncate, but keep the sign
    TAG_INTEGER_REG rax
    ret



section .data

;; buffer for "\n", used by (newline)
align 8
newline_str:
    db 10

;; buffer for storing a single character, used by (putc x)
align 8
putc_buffer:
    db 10

;; zero section
section .bss

;; heap storage
align 16
heap:
    resb 1048576

;; offset used of our heap area.
heap_ptr:
    resq 1

