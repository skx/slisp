;;; NASM assembly file generated by slisp.

;; Compile this with nasm and link like so:
;;
;;    nasm -f elf64 example.s
;;    ld -o example example.o
;;

;; contents
;;
;; 1. macros
;; 2. User-defined functions (defuns)
;; 3. User-defined lambdas
;; 4. entry-point
;; 5. stdlib
;; 6. string-table
;;


;;; 1. macros
;;
;; We use the lower three bits of values to denote their type,
;; string, int, char, lambda, cons, etc.
;;
;; These macros are to be used to tag a register with a given
;; type, or get the type for processing and testing.
;;

;
; If DEBUG is defined we'll return specific error-codes from
; our `fread` implementation, which was helpful for debugging.
;
; Without it defined we'll just return Nil on all failures which
; is what we document, and what the user will expect.
;
%define DEBUG 1
%undef  DEBUG     ;; Comment out this line to enable debugging.

; tag a register as an integer
%macro TAG_INTEGER_REG 1
    sal %1, 3
%endmacro

; tag a register as a string
%macro TAG_STRING_REG 1
    sal %1, 3
    or %1, TAG_ID_STRING
%endmacro

; tag a register as a cons pair
%macro TAG_CONS_REG 1
    sal %1, 3
    or %1, TAG_ID_CONS
%endmacro

; tag a register as a lambda
%macro TAG_LAMBDA_REG 1
    sal %1, 3
    or %1, TAG_ID_LAMBDA
%endmacro


; tag a register as a character
%macro TAG_CHAR_REG 1
    sal %1, 3
    or %1, TAG_ID_CHAR
%endmacro

; tag a register as NIL
%macro TAG_NIL_REG 1
    sal %1, 3
    or %1, TAG_ID_NIL
%endmacro

; remove the tag-bits from a register.
; just shift right 3 bits.
%macro UNTAG_REG 1
    sar %1, 3
%endmacro

; get the tag bits for the given register.
%macro GET_TAG_BITS 1
    and %1, 7
%endmacro

; The value of the tag-bits we use to denote types
TAG_ID_INTEGER equ 0b000
TAG_ID_STRING  equ 0b001
TAG_ID_CONS    equ 0b010
TAG_ID_LAMBDA  equ 0b011
TAG_ID_CHAR    equ 0b100
TAG_ID_NIL     equ 0b111


;;; 2. User-defined functions (defuns)
{{ .Defuns }}

;;; 3. User-defined lambdas
{{ .Lambdas }}

;;; 4. entry-point
global _start
section .text

_start:
    mov rax, heap
    mov [heap_ptr], rax

    mov rcx, [rsp]          ; argc
    lea rbx, [rsp+8]        ; argv

    lea rdx, [rbx + rcx*8 + 8]
    mov [envp_ptr], rdx
    xor rsi, rsi         ; Start with NIL
    TAG_NIL_REG rsi

.loop:
    test rcx, rcx
    jz .done
    dec rcx
    mov rdi, [rbx + rcx*8]  ; argv[rcx]
    TAG_STRING_REG rdi      ; Tag as Lisp string
    call fn_cons            ; cons(string, list)
    mov rsi, rax            ; result becomes next list
    jmp .loop

.done:
    mov rdi, rsi            ; first SysV argument

    call fn_main
    mov rdi, rax            ; exit code is the last expression
    UNTAG_REG rdi
    mov rax, 60
    syscall



;;; 5. stdlib
section .text.typep,"ax",@progbits

;; Is the given value an integer?
intp:
    mov rax, rdi
    GET_TAG_BITS rax
    cmp rax, TAG_ID_INTEGER
    jnz .nil
    mov rax, 1
    TAG_INTEGER_REG rax
    ret
.nil:
    xor rax, rax
    TAG_NIL_REG rax
    ret

section .text.charp,"ax",@progbits

;; Is the given value an character?
charp:
    mov rax, rdi
    GET_TAG_BITS rax
    cmp rax, TAG_ID_CHAR
    jnz .nil
    mov rax, 1
    TAG_INTEGER_REG rax
    ret
.nil:
    xor rax, rax
    TAG_NIL_REG rax
    ret

;; Is the given value a string?
strp:
    mov rax, rdi
    GET_TAG_BITS rax
    cmp rax, TAG_ID_STRING
    jnz .nil
    mov rax, 1
    TAG_INTEGER_REG rax
    ret
.nil:
    xor rax, rax
    TAG_NIL_REG rax
    ret

;; Is the given value a cons?
consp:
    mov rax, rdi
    GET_TAG_BITS rax
    cmp rax, TAG_ID_CONS
    jnz .nil
    mov rax, 1
    TAG_INTEGER_REG rax
    ret
.nil:
    xor rax, rax
    TAG_NIL_REG rax
    ret

;; is the given value a lambda?
lambdap:
    mov rax, rdi
    GET_TAG_BITS rax
    cmp rax, TAG_ID_LAMBDA
    jnz .nil
    mov rax, 1
    TAG_INTEGER_REG rax
    ret
.nil:
    xor rax, rax
    TAG_NIL_REG rax
    ret

;; Is the given value nil?
nilp:
    mov rax, rdi
    GET_TAG_BITS rax
    cmp rax, TAG_ID_NIL
    jnz .nil
    mov rax, 1
    TAG_INTEGER_REG rax
    ret
.nil:
    xor rax, rax
    TAG_NIL_REG rax
    ret


section .text.maths,"ax",@progbits

;; +
integer_plus:
   UNTAG_REG rdi
   UNTAG_REG rsi
   mov rax, rdi
   add rax, rsi
   TAG_INTEGER_REG rax
   ret

;; -
integer_minus:
   UNTAG_REG rdi
   UNTAG_REG rsi
   sub rdi, rsi
   mov rax, rdi
   TAG_INTEGER_REG rax
   ret

;; /
integer_divide:
   UNTAG_REG rdi
   UNTAG_REG rsi

   mov rax, rdi
   cqo
   idiv rsi

   TAG_INTEGER_REG rax
   ret

;; %
integer_modulus:
   UNTAG_REG rdi
   UNTAG_REG rsi

   mov rax, rdi
   cqo
   idiv rsi

   mov rax, rdx
   TAG_INTEGER_REG rax
   ret

;; *
integer_multiply:
   UNTAG_REG rdi
   UNTAG_REG rsi
   mov rax, rdi
   mov rbx, rsi
   imul rbx, rax
   mov rax, rbx
   TAG_INTEGER_REG rax
   ret


section .text.not,"ax",@progbits

;; NOT
;; a nil becomes 1.
;; anything else becomes nil
fn_not:
    mov rax, rdi
    GET_TAG_BITS rax
    cmp rax, TAG_ID_NIL
    jz .nil
    xor rax, rax
    TAG_NIL_REG rax
    ret
.nil:
    mov rax, 1
    TAG_INTEGER_REG rax
    ret

section .text.equals,"ax",@progbits

;; =
equals:
    mov rax, rdi
    mov rbx, rsi
    GET_TAG_BITS rbx     ; type of arg
    GET_TAG_BITS rax     ; type of arg
    cmp rax, rbx
    jnz .nil         ; different types?  Then not equal

    ; If one of the types is a string then we know both are.
    ; RSI/RDI will still have their original values so we can
    ; call strcmp.  If the value is 0 we know they are equal
    cmp rax, TAG_ID_STRING
    jnz .not_strings
    call fn_strcmp
    UNTAG_REG rax
    cmp rax, 0
    jz .equal
    jmp .nil

.not_strings:
    cmp rdi, rsi     ; same types, so compare the values directly
    jnz .nil
.equal:
    mov rax, 1
    TAG_INTEGER_REG rax
    ret
.nil:
    xor rax, rax
    TAG_NIL_REG rax
    ret

section .text.compare,"ax",@progbits

;; <=
lt_equals:
    UNTAG_REG rdi
    UNTAG_REG rsi
    cmp rdi, rsi
    jle .true
    xor rax, rax
    TAG_NIL_REG rax
    ret
.true:
    mov rax, 1
    TAG_INTEGER_REG rax
    ret

;; >=
gt_equals:
    UNTAG_REG rdi
    UNTAG_REG rsi
    cmp rdi, rsi
    jge .true
    xor rax, rax
    TAG_NIL_REG rax
    ret
.true:
    mov rax, 1
    TAG_INTEGER_REG rax
    ret

;; <
lt:
    UNTAG_REG rdi
    UNTAG_REG rsi
    cmp rdi, rsi
    jl .true
    xor rax, rax
    TAG_NIL_REG rax
    ret
.true:
    mov rax, 1
    TAG_INTEGER_REG rax
    ret

;; >
gt:
    UNTAG_REG rdi
    UNTAG_REG rsi
    cmp rdi, rsi
    jg .true
    xor rax, rax
    TAG_NIL_REG rax
    ret
.true:
    mov rax, 1
    TAG_INTEGER_REG rax
    ret

section .text.print_int,"ax",@progbits

;; Print an integer
fn_printint:
    push rbp
    mov rbp, rsp
    sub rsp, 64
    UNTAG_REG rax

    mov r8, 0            ; remember sign
    test rax, rax
    jge .positive
    neg rax
    mov r8, 1
.positive:
    lea rsi, [rsp+63]
    mov byte [rsi], 0
    xor rcx, rcx

.convert:
    xor rdx, rdx
    mov rbx, 10
    div rbx
    add dl, '0'
    dec rsi
    mov [rsi], dl
    inc rcx
    test rax, rax
    jnz .convert

    ; prepend minus sign if needed
    cmp r8, 0
    je .write
    dec rsi
    mov byte [rsi], '-'
    inc rcx
.write:
    mov rax, 1
    mov rdi, 1
    mov rdx, rcx
    syscall
    leave
    ret


section .text.exit,"ax",@progbits

;; terminate execution with the given exit-code
fn_exit:
    UNTAG_REG rdi
    mov rax, 60     ; sys_exit
    syscall
    ret

section .text.newline,"ax",@progbits

;; print a newline.
fn_newline:
    mov rax, 1      ; SYS_write
    mov rdi, 1      ; stdout
    mov rsi, newline_str
    mov rdx, 1
    syscall
    ret

section .text.putc,"ax",@progbits

;; Write the given ASCII character to stdout
fn_putc:
    mov rax, rdi
    UNTAG_REG rax
    mov [putc_buffer],  al  ; store character
    mov rax, 1      ; SYS_write
    mov rdi, 1      ; stdout
    mov rsi, putc_buffer
    mov rdx, 1
    syscall
    ret

section .text.getc,"ax",@progbits

;; Read an ASCII character from STDIN, return NIL on failure.
fn_getc:
     mov     rax, 0        ; SYS_read
     mov     rdi, 0        ; STDIN_FILENO
     mov rsi, putc_buffer
     mov     rdx, 1        ; read 1 byte
     syscall

     cmp rax, 1
     jne .getc_failed

     xor rax,rax
     mov al, byte [putc_buffer]
     TAG_INTEGER_REG rax
     ret
.getc_failed:
     xor rax, rax
     TAG_NIL_REG rax
     ret


section .text.print_str,"ax",@progbits

;; Print the given string.
fn_printstr:
    UNTAG_REG rdi
    push rdi
    mov rdx, 0                ; length counter
.printstr_len_loop:
    cmp byte [rdi + rdx], 0
    je .printstr_found_len
    inc rdx
    jmp .printstr_len_loop
.printstr_found_len:
    pop rsi
    mov rax, 1      ; write
    mov rdi, 1      ; stdout
    syscall

    ret


section .text.chr,"ax",@progbits

;; chr - convert an integer to a character
fn_chr:
    mov rbx, rdi
    GET_TAG_BITS rbx
    cmp rbx, TAG_ID_INTEGER
    jne type_error
    UNTAG_REG rdi
    mov rax, rdi
    and rax, 0xFF        ; Only 0-255 is ASCII
    TAG_CHAR_REG rax
    ret


section .text.ord,"ax",@progbits

;; ord - convert a character to an integer.
fn_ord:
    mov rbx, rdi
    GET_TAG_BITS rbx
    cmp rbx, TAG_ID_CHAR
    jne type_error
    UNTAG_REG rdi
    mov rax, rdi
    TAG_INTEGER_REG rax
    ret

section .text.cons,"ax",@progbits

;; Allocate space for a new cons cell, return it in RAX.
;;
;; 16-bytes; first has the CAR, second the CDR.
fn_cons:
    mov rax, [heap_ptr]      ; get the value of the heap pointer
    add qword [heap_ptr], 16 ; bump it by 2x ptrs
    mov [rax], rdi           ; store first item
    mov [rax+8], rsi         ; second item
    TAG_CONS_REG rax         ; return the tagged allocation
    ret

section .text.car,"ax",@progbits

;; Get the first item in the cons cell.
fn_car:
    mov rbx, rdi
    GET_TAG_BITS rbx
    cmp rbx, TAG_ID_CONS
    jne type_error
    UNTAG_REG rdi
    mov rax, [rdi]
    ret

section .text.cdr,"ax",@progbits

;; Get the second item in the cons cell.
fn_cdr:
    mov rbx, rdi
    GET_TAG_BITS rbx
    cmp rbx, TAG_ID_CONS
    jne type_error
    UNTAG_REG rdi
    mov rax, [rdi + 8]
    ret

type_error:
    jmp fn_exit


section .text.explode,"ax",@progbits


;; Explode a string to a list of characters.
;; find the length and work backwards.
;; This is one of our more complex routines and yet it worked first time :D
fn_explode:
    mov rbx, rdi
    GET_TAG_BITS rbx
    cmp rbx, TAG_ID_STRING
    jne type_error

    UNTAG_REG rdi
    mov rsi, rdi
.find_end:
    cmp byte [rsi], 0
    je .found_end
    inc rsi
    jmp .find_end
.found_end:
    xor rax, rax
    TAG_NIL_REG rax
.loop:
    ; reached beginning?
    cmp rsi, rdi
    je .done
    dec rsi
    movzx rcx, byte [rsi]
    mov rdx, rcx
    TAG_CHAR_REG rdx
    mov r8, [heap_ptr]
    add qword [heap_ptr], 16
    mov [r8], rdx
    mov [r8+8], rax
    mov rax, r8
    TAG_CONS_REG rax
    jmp .loop
.done:
    ret


section .text.implode,"ax",@progbits

;; join a character list to a string
fn_implode:
    mov rbx,rdi
    xor rcx,rcx

.count:
    mov rax,rbx
    GET_TAG_BITS rax
    cmp rax,TAG_ID_NIL
    je .have_len

    ; verify cons
    mov rax,rbx
    GET_TAG_BITS rax
    cmp rax,TAG_ID_CONS
    jne type_error
    inc rcx
    mov rax,rbx
    UNTAG_REG rax
    mov rbx,[rax+8]
    jmp .count

.have_len:
    mov rax,[heap_ptr]
    mov rdx,rcx
    inc rdx
    add [heap_ptr],rdx
    mov r8,rax

    mov rbx,rdi
    xor rcx,rcx
.copy:
    mov rax,rbx
    GET_TAG_BITS rax
    cmp rax,TAG_ID_NIL
    je .finish

    mov rax,rbx
    UNTAG_REG rax
    mov rdx,[rax]
    ; verify char
    mov r9,rdx
    GET_TAG_BITS r9
    cmp r9,TAG_ID_CHAR
    jne type_error
    UNTAG_REG rdx
    mov [r8+rcx],dl
    inc rcx
    mov rbx,[rax+8]
    jmp .copy
.finish:
    mov byte [r8+rcx],0
    mov rax,r8
    TAG_STRING_REG rax
    ret


section .text.strlen,"ax",@progbits

;; Find the length of the given string.
fn_strlen:
    mov rbx, rdi
    GET_TAG_BITS rbx
    cmp rbx, TAG_ID_STRING
    jne type_error

    UNTAG_REG rdi
    xor rax, rax
.find:
    cmp byte [rdi], 0
    je .found_end
    inc rdi
    inc rax
    jmp .find
.found_end:
    TAG_INTEGER_REG rax
    ret

section .text.strcmp,"ax",@progbits

;; Compare the two specified strings.
fn_strcmp:
    mov rbx, rdi             ; type-check arg1
    GET_TAG_BITS rbx
    cmp rbx, TAG_ID_STRING
    jne type_error
    mov rbx, rsi             ; type-check arg2
    GET_TAG_BITS rbx
    cmp rbx, TAG_ID_STRING
    jne type_error

    UNTAG_REG rdi
    UNTAG_REG rsi

.strcmp_next_char:
    mov al, byte [rdi]
    cmp al, byte [rsi]
    jne .strcmp_diff
    test al, al
    je .strcmp_done
    inc rdi
    inc rsi
    jmp .strcmp_next_char
.strcmp_diff:
    movzx rdx, byte [rsi]
    sub al, dl
.strcmp_done:
    movsx rax, al            ; Truncate, but keep the sign
    TAG_INTEGER_REG rax
    ret


section .text.strcat,"ax",@progbigs

;; join the two given strings and return a new one.
fn_strcat:
;; strcat(rdi, rsi)
;;
;; rdi = first string
;; rsi = second string
;;
;; returns tagged string in rax

fn_strcat:
    mov rbx, rdi            ; type-check arg1: str
    GET_TAG_BITS rbx
    cmp rbx, TAG_ID_STRING
    jne type_error
    mov rbx, rsi            ; type-check arg2: str
    GET_TAG_BITS rbx
    cmp rbx, TAG_ID_STRING
    jne type_error

    UNTAG_REG rdi
    UNTAG_REG rsi
    push rdi
    push rsi

    mov rax, rdi
.len1:
    cmp byte [rax],0
    je .len1_done
    inc rax
    jmp .len1
.len1_done:
    sub rax,rdi
    mov r8,rax         ; r8 to save strlen(a)

    mov rax,rsi
.len2:
    cmp byte [rax],0
    je .len2_done
    inc rax
    jmp .len2
.len2_done:
    sub rax,rsi
    mov r9,rax         ; r9 to save strlen(b)

    ; allocate
    mov rax,[heap_ptr]
    mov rcx,r8
    add rcx,r9
    inc rcx                  ; +1 for '\0'
    add [heap_ptr],rcx

    mov rdx,rax              ; destination
    pop rsi                  ; restore strings
    pop rdi

.copy1:                      ; copy first
    mov bl,[rdi]
    test bl,bl
    jz .copy2
    mov [rdx],bl
    inc rdi
    inc rdx
    jmp .copy1

.copy2:                      ; append second
    mov bl,[rsi]
    test bl,bl
    jz .done
    mov [rdx],bl
    inc rsi
    inc rdx
    jmp .copy2

.done:                       ; terminate and return
    mov byte [rdx],0
    TAG_STRING_REG rax
    ret



section .text.random,"ax",@progbits

;; Generate a random number 0-N
fn_random:
    mov rbx, rdi             ; type-check arg1
    GET_TAG_BITS rbx
    cmp rbx, TAG_ID_INTEGER
    jne type_error

    UNTAG_REG rdi
    push rdi                        ; push the limit

    mov rax, 318               ; syscall: getrandom
    lea rdi, [ random_buffer]  ; random value location
    mov rsi, 4                 ; number of bytes
    xor rdx, rdx               ; flags = 0
    syscall

    pop rcx                    ; limit the value
    mov eax, [random_buffer]
    xor edx, edx
    div ecx

    mov rax, rdx
    TAG_INTEGER_REG rax
    ret



section .text.fclose,"ax",@progbits

;; Close a file handle
;;
;; As a special case closing a nil-filehandle is valid.
;;
fn_fclose:
    mov rbx, rdi             ; type-check arg1 (path)
    GET_TAG_BITS rbx
    cmp rbx, TAG_ID_NIL
    je .fclose_return_nil
    cmp rbx, TAG_ID_INTEGER
    jne type_error

    UNTAG_REG rdi
    mov rax, 3            ; SYS_close
    syscall
    xor rax, rax          ; return nil
.fclose_return_nil:
    TAG_NIL_REG rax
    ret



section .text.fopen,"ax",@progbits

;; Open a file handle, modes are "r", "w", or "a"
fn_fopen:
    mov rbx, rdi             ; type-check arg1 (path)
    GET_TAG_BITS rbx
    cmp rbx, TAG_ID_STRING
    jne type_error

    mov rbx, rsi             ; type-check arg2 (mode)
    GET_TAG_BITS rbx
    cmp rbx, TAG_ID_STRING
    jne type_error

    UNTAG_REG rdi
    UNTAG_REG rsi

    mov al, [rsi]          ; We only look at the first character..
    cmp al, 'a'
    je .fopen_append
    cmp al, 'r'
    je .fopen_read
    cmp al, 'w'
    je .fopen_write

    ; fall through to bad mode
    xor rax, rax
    TAG_NIL_REG rax
    ret

.fopen_append:
        mov rax, 2          ; SYS_open
        mov rsi, 1089       ; O_WRONLY|O_CREAT|O_APPEND
        mov rdx, 0644
        syscall
        jmp .fopen_done
.fopen_read:
        mov rax, 2          ; SYS_open
        mov rsi, 0          ; O_RDONLY
        xor rdx, rdx
        syscall
        jmp .fopen_done
.fopen_write:
        mov rax, 2          ; SYS_open
        mov rsi, 577        ; O_WRONLY|O_CREAT|O_TRUNC
        mov rdx, 0o644
        syscall
.fopen_done:
        test rax, rax
        js .fopen_syscall_fail
        TAG_INTEGER_REG rax
        ret
.fopen_syscall_fail:
        xor rax, rax
        TAG_NIL_REG rax
        ret


section .text.fread,"ax",@progbits

;; Read ALL data from the given file handle.
;;
;; As a special case reading from a nil-filehandle
;; will return nil.
fn_fread:
        mov rbx, rdi             ; type-check arg1
        GET_TAG_BITS rbx
        cmp rbx, TAG_ID_NIL      ; special case the nil-handle
        je .fread_return_nil
        cmp rbx, TAG_ID_INTEGER
        jne type_error

        UNTAG_REG rdi
        mov [random_buffer], rdi   ; save file handle

        mov rax, 8                 ; SYS_lseek
        xor rsi, rsi               ; offset = 0
        mov rdx, 2                 ; SEEK_END
        syscall

        test rax, rax
        js .fread_seek_end_fail

        mov rbx, rax                ; file size
        push rbx                    ; save size

        ; allocate size+1 bytes
        mov rdi, rbx
        inc rdi

        mov rax, [heap_ptr]       ; rax contains allocated storage
        add qword [heap_ptr], rdi

        pop rbx                   ; restore size
        mov r12, rax              ; data pointer in r12.

        mov rax, 8                ; seek to start of file
        mov rdi,[random_buffer]   ; saved file handle
        xor rsi, rsi
        xor rdx, rdx              ; SEEK_SET
        syscall

        test rax, rax
        js .fread_seek_start_fail

        ; Read until we've consumed the entire file.
        xor r13, r13       ; bytes_read_so_far = 0

.read_loop:

        cmp r13, rbx                ; got all the file?  Yay!
        je .read_complete

        mov rdi, [random_buffer]    ; file handle
        lea rsi, [r12+r13]          ; destination offset

        mov rdx, rbx
        sub rdx, r13                ; remaining bytes

        xor rax, rax                ; SYS_read
        syscall

        test rax, rax               ; failed to read
        js .fread_read_fail

        test rax, rax
        je .fread_short_read         ; unexpected EOF

        add r13, rax
        jmp .read_loop

.read_complete:
        mov byte [r12+r13], 0   ; null-terminate
        mov rax, r12
        TAG_STRING_REG rax
        ret

%ifdef DEBUG
.fread_short_read:
        mov rax, 1
        TAG_INTEGER_REG rax
        ret
.fread_read_fail:
        mov rax, 2
        TAG_INTEGER_REG rax
        ret
.fread_seek_start_fail:
        mov rax, 3
        TAG_INTEGER_REG rax
        ret
.fread_seek_end_fail:
        mov rax, 4
        TAG_INTEGER_REG rax
        ret
.fread_return_nil:
        xor rax,rax
        TAG_NIL_REG rax
        ret
%else
.fread_short_read:
.fread_read_fail:
.fread_seek_start_fail:
.fread_seek_end_fail:
.fread_return_nil:
        xor rax,rax
        TAG_NIL_REG rax
        ret
%endif



section .text.fwrite,"ax",@progbits

;; Write data, with a size, to the given file handle
;; e.g.  (fwrite handle "Steve" 5)
;;
;; As a special case writing to a nil-filehandle
;; will return nil.
fn_fwrite:
        mov rbx, rdi             ; type-check arg1: int
        GET_TAG_BITS rbx
        cmp rbx, TAG_ID_NIL      ; special case the nil-handle
        je .fwrite_return_nil
        cmp rbx, TAG_ID_INTEGER
        jne type_error

        mov rbx, rsi             ; type-check arg2: str
        GET_TAG_BITS rbx
        cmp rbx, TAG_ID_STRING
        jne type_error

        mov rbx, rdx             ; type-check arg3: int
        GET_TAG_BITS rbx
        cmp rbx, TAG_ID_INTEGER
        jne type_error

        UNTAG_REG rsi
        UNTAG_REG rdi
        UNTAG_REG rdx

        mov rax, 1             ; SYS_write
        syscall
        TAG_INTEGER_REG rax
        ret

.fwrite_return_nil:
        xor rax,rax
        TAG_NIL_REG rax
        ret

section .text.environment,"ax",@progbits

;; Return a list of all environmental variables
fn_environment:
    mov rbx, [envp_ptr]
    xor rcx, rcx     ;; Count entries into RCX
.count:
    mov rdx, [rbx + rcx*8]
    test rdx, rdx
    jz .build
    inc rcx
    jmp .count
.build:
    xor rax, rax
    TAG_NIL_REG rax
.loop:
    test rcx, rcx
    jz .done
    dec rcx

    ;; string pointer
    mov rdx, [rbx + rcx*8]
    TAG_STRING_REG rdx

    ;; allocate cons pair
    mov r8, [heap_ptr]
    add qword [heap_ptr], 16
    mov [r8], rdx        ; car = string
    mov [r8+8], rax      ; cdr = list-so-far
    mov rax, r8
    TAG_CONS_REG rax
    jmp .loop
.done:
    ret


;; split(string, char)
fn_split:
    mov rbx, rdi              ; type-check arg1: string
    GET_TAG_BITS rbx
    cmp rbx, TAG_ID_STRING
    jne type_error
    mov rbx, rsi              ; type-check arg2: char
    GET_TAG_BITS rbx
    cmp rbx, TAG_ID_CHAR
    jne type_error

    UNTAG_REG rdi
    UNTAG_REG rsi

    and rsi, 0xff            ; separator byte

    mov r8, rdi              ; original string

    xor rcx, rcx             ; offset for finding separator
.find:
    mov al, [rdi]
    test al, al
    jz .not_found
    cmp al, sil
    je .found
    inc rdi
    inc rcx
    jmp .find

.not_found:                   ; separator not found in string -> nil
    xor rax, rax
    TAG_NIL_REG rax
    ret

.found:
    mov r10, [heap_ptr]       ; allocate left
    mov r11, r10

    mov rax, rcx
    inc rax
    add [heap_ptr], rax

    mov rsi, rcx
    mov rdx, r8

.copy_left:                   ; copy left
    test rsi, rsi
    jz .left_done
    mov al, [rdx]
    mov [r11], al
    inc r11
    inc rdx
    dec rsi
    jmp .copy_left

.left_done:
    mov byte [r11], 0
    mov rax, r10
    TAG_STRING_REG rax
    mov r10, rax

    lea rdx, [rdi+1]      ; get length of right
    xor rcx, rcx

.count_right:
    mov al, [rdx]
    test al, al
    jz .alloc_right
    inc rcx
    inc rdx
    jmp .count_right

.alloc_right:
    mov r11, [heap_ptr]   ; allocate
    mov r12, r11
    mov rax, rcx
    inc rax
    add [heap_ptr], rax

    lea rdx, [rdi+1]
    mov rsi, rcx
.copy_right:
    test rsi, rsi
    jz .right_done
    mov al, [rdx]
    mov [r12], al
    inc r12
    inc rdx
    dec rsi
    jmp .copy_right

.right_done:
    mov byte [r12], 0
    mov rax, r11
    TAG_STRING_REG rax
    mov r11, rax

    xor rax, rax                    ; right
    TAG_NIL_REG rax
    mov rbx, [heap_ptr]
    add qword [heap_ptr],16
    mov [rbx], r11
    mov [rbx+8], rax
    mov rax, rbx
    TAG_CONS_REG rax

    mov rbx, [heap_ptr]
    add qword [heap_ptr],16
    mov [rbx], r10
    mov [rbx+8], rax
    mov rax, rbx
    TAG_CONS_REG rax
    ret


section .data

;; buffer for "\n", used by (newline)
align 8
newline_str:
    db 10

;; buffer for storing a single character, used by (putc x)
align 8
putc_buffer:
    db 10

;; buffer for our random function to read into
align 8
random_buffer:
    db 0x01, 0x02, 0x03, 0x04

;; zero section
section .bss

;; heap storage
align 16
heap:
    resb 1 * 1024 * 1024 * 1024  ; 1 Mb

;; offset used of our heap area.
heap_ptr:
    resq 1

;; start of the environmental variable array
envp_ptr:
    resq 1

