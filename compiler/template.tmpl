;;; 4. entry-point
global _start
section .text

_start:
    mov rax, heap
    mov [heap_ptr], rax

    mov rcx, [rsp]             ; argc
    lea rbx, [rsp+8]           ; argv

    lea rdx, [rbx + rcx*8 + 8] ; start of environmental variables
    mov [envp_ptr], rdx        ; save that
    xor rsi, rsi               ; Start with NIL
    TAG_NIL_REG rsi
.loop:                         ; build up a list of cli arguments in a list
    test rcx, rcx
    jz .done
    dec rcx
    mov rdi, [rbx + rcx*8]     ; argv[rcx]
    TAG_STRING_REG rdi         ; Tag as Lisp string
    call fn_cons               ; cons(string, list)
    mov rsi, rax               ; result becomes next list
    jmp .loop
.done:
    mov rdi, rsi               ; first SysV argument
    call fn_main
    mov rdi, rax               ; exit code is the last expression
    UNTAG_REG rdi
    mov rax, SYS_exit
    syscall



;;; 5. stdlib


;;; 5.1 type-checking utilities

;; Extract the tag-bits, and see if they match RBX
;; If they do return the integer 1, otherwise nil
is_type:
    mov rax, rdi
    GET_TAG_BITS rax
    cmp rax, rbx
    jnz .nil
    mov rax, 1
    TAG_INTEGER_REG rax
    ret
.nil:
    xor rax, rax
    TAG_NIL_REG rax
    ret


;; Is the given value an character?
charp:
    mov rbx, TAG_ID_CHAR
    jmp is_type

;; Is the given value a cons?
consp:
    mov rbx, TAG_ID_CONS
    jmp is_type

;; Is the given value a float?
floatp:
    mov rbx, TAG_ID_FLOAT
    jmp is_type

;; Is the given value an integer?
intp:
    mov rbx, TAG_ID_INTEGER
    jmp is_type

;; is the given value a lambda?
lambdap:
    mov rbx, TAG_ID_LAMBDA
    jmp is_type

;; Is the given value nil?
nilp:
    mov rbx, TAG_ID_NIL
    jmp is_type

;; Is the given value a string?
strp:
    mov rbx, TAG_ID_STRING
    jmp is_type


;; numeric?
numericp:
    mov rax, rdi
    GET_TAG_BITS rax
    call is_numeric
    cmp rax, 0
    jnz .true
.nil:
    xor rax, rax
    TAG_NIL_REG rax
    ret
.true:
    mov rax, 1
    TAG_INTEGER_REG rax
    ret


;; Internal helper
is_numeric:
    cmp rax,TAG_ID_INTEGER
    je .yes
    cmp rax,TAG_ID_FLOAT
    je .yes
    cmp rax,TAG_ID_CHAR
    je .yes
    xor eax,eax
    ret
.yes:
    mov eax,1
    ret



;;; 5.2. math functions


;; helper - are both arguments integers?
;;
;; Here "both" means RDI and RSI which are the
;; first two arguments according to the SysV ABI
;;
;; We use these for maths/comparison operations.
are_both_integers:
   mov rax, rdi
   mov rbx, rsi
   GET_TAG_BITS rbx     ; type of arg
   GET_TAG_BITS rax     ; type of arg
   add rax, rbx         ; both integers? == 0
   ret

;; helper - load both floating point numbers.
;;
;; Here "both" means RDI and RSI which are the
;; first two arguments according to the SysV ABI.
;;
;; We only use this function if both arguments
;; are not integers.  So one/both arg might be
;; a float, but we have to test and decide.
;;
;; When this function returns xmm0 and xmm1 will
;; have the two arguments anyway.
load_both_floats:
   mov rcx, rdi
   UNTAG_REG rdi
   GET_TAG_BITS rcx
   cmp rcx, TAG_ID_FLOAT
   jz .arg_one_float
   cmp rcx, TAG_ID_INTEGER
   jz .arg_one_int
   cmp rcx, TAG_ID_CHAR
   je .arg_one_int
   jmp type_error

.arg_one_int:
    cvtsi2sd xmm0, rdi ; convert to float
    jmp .arg_two
.arg_one_float:
    movq xmm0, [rdi]   ; load
    ; jmp .arg_two     ; fall through

.arg_two:
   mov rcx, rsi
   UNTAG_REG rsi
   GET_TAG_BITS rcx
   cmp rcx, TAG_ID_FLOAT
   jz .arg_two_float
   cmp rcx, TAG_ID_INTEGER
   jz .arg_two_int
   cmp rcx, TAG_ID_CHAR
   jz .arg_two_int
   jmp type_error

.arg_two_int:
   cvtsi2sd xmm1, rsi ; convert to float
   ret
.arg_two_float:
   movq xmm1, [rsi]      ; load
   ret


;; +
FUNC plus
   call are_both_integers
   jz plus_integer

   call load_both_floats
   addsd xmm0, xmm1        ; add
   mov rax, [heap_ptr]     ; allocate
   add qword [heap_ptr],8
   movq [rax], xmm0        ; store
   TAG_FLOAT_REG rax       ; type
   ret                     ; return

plus_integer:
   UNTAG_REG rdi
   UNTAG_REG rsi
   mov rax, rdi
   add rax, rsi
   TAG_INTEGER_REG rax
   ret



;; -
FUNC minus
   call are_both_integers
   jz integer_minus

   call load_both_floats
   subsd xmm0, xmm1        ; subtrack
   mov rax, [heap_ptr]     ; allocate
   add qword [heap_ptr],8
   movq [rax], xmm0        ; store
   TAG_FLOAT_REG rax       ; type
   ret                     ; return

integer_minus:
   UNTAG_REG rdi
   UNTAG_REG rsi
   sub rdi, rsi
   mov rax, rdi
   TAG_INTEGER_REG rax
   ret



;; /
FUNC divide
   call are_both_integers
   jz integer_divide

   call load_both_floats
   divsd xmm0, xmm1        ; multiply
   mov rax, [heap_ptr]     ; allocate
   add qword [heap_ptr],8
   movq [rax], xmm0        ; store
   TAG_FLOAT_REG rax       ; type
   ret                     ; return

integer_divide:
   UNTAG_REG rdi
   UNTAG_REG rsi
   mov rax, rdi
   cqo
   idiv rsi
   TAG_INTEGER_REG rax
   ret



;; *
FUNC multiply
   call are_both_integers
   jz integer_multiply

   call load_both_floats
   mulsd xmm0, xmm1        ; multiply
   mov rax, [heap_ptr]     ; allocate
   add qword [heap_ptr],8
   movq [rax], xmm0        ; store
   TAG_FLOAT_REG rax       ; type
   ret                     ; return

integer_multiply:
   UNTAG_REG rdi
   UNTAG_REG rsi
   mov rax, rdi
   mov rbx, rsi
   imul rbx, rax
   mov rax, rbx
   TAG_INTEGER_REG rax
   ret



;; %
FUNC modulus
   call are_both_integers
   jz modulus_integer
   jmp type_error       ; type error
modulus_integer:
   UNTAG_REG rdi
   UNTAG_REG rsi        ; untag arguments
   mov rax, rdi         ; do the magic
   cqo
   idiv rsi
   mov rax, rdx         ; result is an integer
   TAG_INTEGER_REG rax
   ret



;;; 5.2.1 comparison functions

;; =
FUNC equals
    mov r8, rdi
    mov r9, rsi

    GET_TAG_BITS r8
    GET_TAG_BITS r9

    cmp r8, r9               ; Two diferent types, assume INT/CHAR/FLOAT
    jne .different_types

    cmp r8, TAG_ID_CHAR      ; Two characters - compare
    je .compare_chars
    cmp r8, TAG_ID_FLOAT     ; Two floats - compare
    je .compare_floats
    cmp r8, TAG_ID_INTEGER   ; Two integers - compare
    je .compare_ints
    cmp r8, TAG_ID_STRING    ; Two strings - compare
    je .compare_strings

    jmp .compare_bits        ; Just compare directly e.g. "= nil 3"

.compare_bits:               ; Same type and same value?
    cmp rdi, rsi
    je .equal
    jmp .nil

;; Lump them all together into "convert A B to floats and compare"
.compare_ints:
.compare_floats:
.compare_chars:
.different_types:            ; Compare different (numeric) types
    mov rax,r8               ; Numeric?
    call is_numeric
    test al,al
    jz .nil

    mov rax,r9               ; Numeric?
    call is_numeric
    test al,al
    jz .nil

    call load_both_floats    ; Compare numerically
    ucomisd xmm0,xmm1
    je .equal
    jmp .nil

.compare_strings:
    call fn_strcmp           ; RSI / RDI are untouhced
    UNTAG_REG rax            ; delegate to strcmp
    cmp rax, 0
    jz .equal
    jmp .nil

.equal:
    mov rax, 1
    TAG_INTEGER_REG rax
    ret
.nil:
    xor rax, rax
    TAG_NIL_REG rax
    ret



;; <= - Work with either integers, floats, or both.
;;
;; Note: The result of this function is inverted for ">".
;;
FUNC lt_equals
   call are_both_integers
   jz lte_integer

   call load_both_floats
   ucomisd xmm0, xmm1
   jbe lte_integer.true
   jmp lte_integer.false

lte_integer:
    UNTAG_REG rdi
    UNTAG_REG rsi
    cmp rdi, rsi
    jle .true
.false:
    xor rax, rax
    TAG_NIL_REG rax
    ret
.true:
    mov rax, 1
    TAG_INTEGER_REG rax
    ret



;; >=
FUNC gt_equals
   call are_both_integers
   jz gte_integer

   call load_both_floats
   ucomisd xmm0, xmm1
   jb  gte_integer.false
   jmp gte_integer.true

gte_integer:
    UNTAG_REG rdi
    UNTAG_REG rsi
    cmp rdi, rsi
    jge .true
.false:
    xor rax, rax
    TAG_NIL_REG rax
    ret
.true:
    mov rax, 1
    TAG_INTEGER_REG rax
    ret



;; < - this is the inverse of >=
FUNC lt
    call gt_equals
    mov rdi, rax
    call fn_not
    ret



;; > - this is the inverse of <=
FUNC gt
    call lt_equals
    mov rdi, rax
    call fn_not
    ret




;;; 5.3 printing functions

section .text.printing,"ax",@progbits

;; print a newline.
fn_newline:
    mov rax, SYS_write
    mov rdi, 1              ; stdout
    mov rsi, random_buffer  ; point to the buffer
    mov byte [rsi], 10      ; add a newline character there
    mov rdx, 1
    syscall
    ret



;; Print a float
fn_printfloat:
    mov rbx, rdi
    GET_TAG_BITS rbx
    cmp rbx, TAG_ID_FLOAT
    jne type_error

    UNTAG_REG rdi      ; RAX has pointer
    movq xmm0, [rdi]   ; get the value

    ; format into the random buffer, and return it.
    call fn_printfloat_format
.write:
    mov rax, SYS_write
    mov rdi, 1
    mov rdx, rcx
    syscall

    xor rax,rax           ; return nil
    TAG_NIL_REG rax
    ret


;; convert the (untagged) float in xmm0 into a string.
;;
;; This reuses the "random_buffer", so you need to copy
;; the value elsewhere if you want to keep it.
;;
;; On return RSI pointing to the formatted result,
;; with RCX holding the length.
fn_printfloat_format:
    xor r8, r8                      ; sign flag

    xorpd xmm1, xmm1                ; Handle sign
    ucomisd xmm0, xmm1
    jae .positive

    mov r8, 1
    movq xmm1, [rel minusmask]
    xorpd xmm0, xmm1

.positive:
    cvttsd2si r9, xmm0             ; Integer part -> R9

    movsd xmm1, [rel million]      ; Fraction = trunc(x*1e6) - integer*1e6
    mulsd xmm0, xmm1
    cvttsd2si rbx, xmm0

    mov rax, r9
    imul rax, 1000000
    sub rbx, rax                   ; RBX = fractional value

    lea rsi, [random_buffer_end]
    mov byte [rsi], 0
    xor rcx, rcx

    mov r10, 6                     ; Emit exactly six fractional digits
.frac_loop:
    xor rdx, rdx
    mov rax, rbx
    mov r11, 10
    div r11

    add dl, '0'
    dec rsi
    mov [rsi], dl

    mov rbx, rax
    inc rcx

    dec r10
    jnz .frac_loop

    ; Decimal point
    dec rsi
    mov byte [rsi], '.'
    inc rcx

    ; Integer digits
    mov rax, r9

.int_loop:                      ; divide by ten for each digiti
    xor rdx, rdx
    mov r11, 10
    div r11

    add dl, '0'
    dec rsi
    mov [rsi], dl
    inc rcx

    test rax, rax
    jnz .int_loop

    test r8, r8                ; was this negative?
    jz .done

    dec rsi
    mov byte [rsi], '-'
    inc rcx
.done:
    ret



;; Print an integer.
fn_printint:
    mov rbx, rdi
    GET_TAG_BITS rbx
    cmp rbx, TAG_ID_INTEGER
    jne type_error
    mov rax, rdi
    UNTAG_REG rax

    ; format the integer into the
    ; random buffer, and return it.
    call fn_printint_format
.write:
    mov rax, SYS_write
    mov rdi, 1
    mov rdx, rcx
    syscall

    xor rax,rax           ; return nil
    TAG_NIL_REG rax
    ret

;; convert the (untagged) integer in RAX into a string.
;;
;; This reuses the "random_buffer", so you need to copy
;; the value elsewhere if you want to keep it.
;;
;; On return RSI pointing to the formatted result,
;; with RCX holding the length.
fn_printint_format:
    mov r8, 0            ; remember sign
    test rax, rax
    jge .positive
    neg rax
    mov r8, 1
.positive:
    lea rsi, random_buffer_end   ; end of random buffer
    mov byte [rsi], 0
    xor rcx, rcx
.convert:
    xor rdx, rdx
    mov rbx, 10
    div rbx
    add dl, '0'
    dec rsi                       ; we move backward.
    mov [rsi], dl
    inc rcx
    test rax, rax
    jnz .convert

    cmp r8, 0     ; prepend minus sign if needed
    je .done
    dec rsi
    mov byte [rsi], '-'   ; add the sign, and increase count
    inc rcx
.done:
    ret


;; Print the given string.
fn_printstr:
    mov rbx, rdi
    GET_TAG_BITS rbx
    cmp rbx, TAG_ID_STRING
    jne type_error
    UNTAG_REG rdi
    push rdi
    mov rdx, 0                ; length counter
.printstr_len_loop:
    cmp byte [rdi + rdx], 0
    je .printstr_found_len
    inc rdx
    jmp .printstr_len_loop
.printstr_found_len:
    pop rsi
    mov rax, SYS_write
    mov rdi, 1                ; stdout
    syscall
    ret



;;; 5.4. fn_XXX - alphabetical order

;; Get the first item in the cons cell.
;; Note: calling (car nil) will return nil.
FUNC fn_car
    mov rbx, rdi
    GET_TAG_BITS rbx
    cmp rbx, TAG_ID_NIL
    jz .nil
    cmp rbx, TAG_ID_CONS
    jne type_error
    UNTAG_REG rdi
    mov rax, [rdi]
    ret
.nil:
    xor rax, rax
    TAG_NIL_REG rax
    ret



;; Get the second item in the cons cell.
;; Note: calling (cdr nil) will return nil.
FUNC fn_cdr
    mov rbx, rdi
    GET_TAG_BITS rbx
    cmp rbx, TAG_ID_NIL
    jz .nil
    cmp rbx, TAG_ID_CONS
    jne type_error
    UNTAG_REG rdi
    mov rax, [rdi + 8]
    ret
.nil:
    xor rax, rax
    TAG_NIL_REG rax
    ret



;; chr - convert an integer to a character
FUNC fn_chr
    mov rbx, rdi
    GET_TAG_BITS rbx
    cmp rbx, TAG_ID_INTEGER
    jne type_error
    UNTAG_REG rdi
    mov rax, rdi
    and rax, 0xFF        ; Only 0-255 is ASCII
    TAG_CHAR_REG rax
    ret



;; Allocate space for a new cons cell, return it in RAX.
;;
;; 16-bytes; first has the CAR, second the CDR.
FUNC fn_cons
    mov rax, [heap_ptr]      ; get the value of the heap pointer
    add qword [heap_ptr], 16 ; bump it by 2x ptrs
    mov [rax], rdi           ; store first item
    mov [rax+8], rsi         ; second item
    TAG_CONS_REG rax         ; return the tagged allocation
    ret



;; Return a list of directory-entries beneath the given prefix.
;; Return nil on failure.
FUNC fn_entries
    mov rbx, rdi
    GET_TAG_BITS rbx
    cmp rbx, TAG_ID_STRING
    jne type_error

    UNTAG_REG rdi

    mov eax, SYS_open                     ; Open the directory for processing.
    mov esi, O_RDONLY | O_DIRECTORY
    xor edx, edx
    syscall
    test rax, rax
    js .failure

    mov r12, rax                           ; directory fd

    xor r13, r13                           ; End of the list will have NIL in it.
    TAG_NIL_REG r13

.read_directory:
    mov eax, SYS_getdents64                ; Read the entries
    mov rdi, r12
    mov rsi, dir_buffer
    mov edx, dir_buffer_end - dir_buffer
    syscall
    test rax, rax
    js .close_failure
    test rax, rax
    jz .done_reading

    mov r14, dir_buffer                    ; Process each entry in a loop
    lea r15, [dir_buffer + rax]
.next_entry:
    cmp r14, r15
    jae .read_directory


    movzx ebx, word [r14+16]               ; Save record length
    lea r8, [r14+19]                       ; Get the filename

    xor r9, r9                             ; Get the length of the filename in r9
.length_loop:
    cmp byte [r8+r9], 0
    je .length_done
    inc r9
    jmp .length_loop

.length_done:
    mov r10, r9                             ; Allocate length+1 (rounded)
    inc r10
    add r10, 7
    and r10, -8
    mov r11, [heap_ptr]
    add [heap_ptr], r10

    mov rdi, r11                            ; Copy string into newly allocated memory in R11
    mov rsi, r8
.copy:
    mov al, [rsi]
    mov [rdi], al
    inc rsi
    inc rdi
    test al, al
    jne .copy

    mov rdi, r11                            ; The entry is a string
    TAG_STRING_REG rdi

    mov rsi, r13                            ; Add to our list
    call fn_cons

    mov r13, rax                            ; Save the updated list head

    add r14, rbx                            ; Process the next entry
    jmp .next_entry

.done_reading:
    mov eax, SYS_close                      ; Close the directory
    mov rdi, r12
    syscall
    mov rax, r13                            ; Return the list
    ret
.close_failure:
    mov eax, SYS_close
    mov rdi, r12
    syscall
.failure:
    xor rax, rax
    TAG_NIL_REG rax
    ret




;; Return a list of all environmental variables
FUNC fn_environment
    mov rbx, [envp_ptr]
    xor rcx, rcx     ;; Count entries into RCX
.count:
    mov rdx, [rbx + rcx*8]
    test rdx, rdx
    jz .build
    inc rcx
    jmp .count
.build:
    xor rax, rax
    TAG_NIL_REG rax
.loop:
    test rcx, rcx
    jz .done
    dec rcx

    ;; string pointer
    mov rdx, [rbx + rcx*8]
    TAG_STRING_REG rdx

    ;; allocate cons pair
    mov r8, [heap_ptr]
    add qword [heap_ptr], 16
    mov [r8], rdx        ; car = string
    mov [r8+8], rax      ; cdr = list-so-far
    mov rax, r8
    TAG_CONS_REG rax
    jmp .loop
.done:
    ret



;; terminate execution with the given exit-code
FUNC fn_exit
    UNTAG_REG rdi
    mov rax, SYS_exit
    syscall
    ret



;; Explode a string to a list of characters.
;; Find the length and work backwards.
FUNC fn_explode
    mov rbx, rdi
    GET_TAG_BITS rbx
    cmp rbx, TAG_ID_STRING
    jne type_error

    UNTAG_REG rdi
    mov rsi, rdi
.find_end:
    cmp byte [rsi], 0
    je .found_end
    inc rsi
    jmp .find_end
.found_end:
    xor rax, rax
    TAG_NIL_REG rax
.loop:
    ; reached beginning?
    cmp rsi, rdi
    je .done
    dec rsi
    movzx rcx, byte [rsi]
    mov rdx, rcx
    TAG_CHAR_REG rdx
    mov r8, [heap_ptr]
    add qword [heap_ptr], 16
    mov [r8], rdx
    mov [r8+8], rax
    mov rax, r8
    TAG_CONS_REG rax
    jmp .loop
.done:
    ret



;; Close a file handle
;;
;; As a special case closing a nil-filehandle is valid.
;;
FUNC fn_fclose
    mov rbx, rdi             ; type-check arg1 (path)
    GET_TAG_BITS rbx
    cmp rbx, TAG_ID_NIL
    je .fclose_return_nil
    cmp rbx, TAG_ID_INTEGER
    jne type_error

    UNTAG_REG rdi
    mov rax, SYS_close
    syscall
    xor rax, rax          ; return nil
.fclose_return_nil:
    TAG_NIL_REG rax
    ret



;; Open a file handle, modes are "r", "w", or "a"
FUNC fn_fopen
    mov rbx, rdi             ; type-check arg1 (path)
    GET_TAG_BITS rbx
    cmp rbx, TAG_ID_STRING
    jne type_error

    mov rbx, rsi             ; type-check arg2 (mode)
    GET_TAG_BITS rbx
    cmp rbx, TAG_ID_STRING
    jne type_error

    UNTAG_REG rdi
    UNTAG_REG rsi

    mov al, [rsi]          ; We only look at the first character..
    cmp al, 'a'
    je .fopen_append
    cmp al, 'r'
    je .fopen_read
    cmp al, 'w'
    je .fopen_write

    ; fall through to bad mode
    xor rax, rax
    TAG_NIL_REG rax
    ret

.fopen_append:
        mov rax, SYS_open
        mov rsi, 1089       ; O_WRONLY|O_CREAT|O_APPEND
        mov rdx, 0o644
        syscall
        jmp .fopen_done
.fopen_read:
        mov rax, SYS_open
        mov rsi, 0          ; O_RDONLY
        xor rdx, rdx
        syscall
        jmp .fopen_done
.fopen_write:
        mov rax, SYS_open
        mov rsi, 577        ; O_WRONLY|O_CREAT|O_TRUNC
        mov rdx, 0o644
        syscall
.fopen_done:
        test rax, rax
        js .fopen_syscall_fail
        TAG_INTEGER_REG rax
        ret
.fopen_syscall_fail:
        xor rax, rax
        TAG_NIL_REG rax
        ret



;; Read ALL data from the given file handle.
;;
;; As a special case reading from a nil-filehandle
;; will return nil.
FUNC fn_fread
        mov rbx, rdi             ; type-check arg1
        GET_TAG_BITS rbx
        cmp rbx, TAG_ID_NIL      ; special case the nil-handle
        je .fread_return_nil
        cmp rbx, TAG_ID_INTEGER
        jne type_error

        UNTAG_REG rdi
        mov [random_buffer], rdi   ; save file handle

        mov rax, SYS_lseek
        xor rsi, rsi               ; offset = 0
        mov rdx, 2                 ; SEEK_END
        syscall

        test rax, rax
        js .fread_seek_end_fail

        mov rbx, rax                ; file size
        push rbx                    ; save size

        ; allocate size+1 bytes
        mov rdi, rbx
        inc rdi

        mov rax, [heap_ptr]       ; rax contains allocated storage
        add qword [heap_ptr], rdi

        pop rbx                   ; restore size
        mov r12, rax              ; data pointer in r12.

        mov rax, 8                ; seek to start of file
        mov rdi,[random_buffer]   ; saved file handle
        xor rsi, rsi
        xor rdx, rdx              ; SEEK_SET
        syscall

        test rax, rax
        js .fread_seek_start_fail

        ; Read until we've consumed the entire file.
        xor r13, r13       ; bytes_read_so_far = 0

.read_loop:

        cmp r13, rbx                ; got all the file?  Yay!
        je .read_complete

        mov rdi, [random_buffer]    ; file handle
        lea rsi, [r12+r13]          ; destination offset

        mov rdx, rbx
        sub rdx, r13                ; remaining bytes

        mov rax, SYS_read
        syscall

        test rax, rax               ; failed to read
        js .fread_read_fail

        test rax, rax
        je .fread_short_read         ; unexpected EOF

        add r13, rax
        jmp .read_loop

.read_complete:
        mov byte [r12+r13], 0   ; null-terminate
        mov rax, r12
        TAG_STRING_REG rax
        ret

%ifdef DEBUG
.fread_short_read:
        mov rax, 1
        TAG_INTEGER_REG rax
        ret
.fread_read_fail:
        mov rax, 2
        TAG_INTEGER_REG rax
        ret
.fread_seek_start_fail:
        mov rax, 3
        TAG_INTEGER_REG rax
        ret
.fread_seek_end_fail:
        mov rax, 4
        TAG_INTEGER_REG rax
        ret
.fread_return_nil:
        xor rax,rax
        TAG_NIL_REG rax
        ret
%else
.fread_short_read:
.fread_read_fail:
.fread_seek_start_fail:
.fread_seek_end_fail:
.fread_return_nil:
        xor rax,rax
        TAG_NIL_REG rax
        ret
%endif





;; Write data, with a size, to the given file handle
;; e.g.  (fwrite handle "Steve" 5)
