;; Read an ASCII character from STDIN, return NIL on failure.
FUNC fn_getc
     mov     rax, SYS_read
     mov     rdi, 0        ; STDIN
     mov rsi, random_buffer
     mov     rdx, 1        ; 1 byte
     syscall

     cmp rax, 1
     jne .getc_failed

     xor rax,rax
     mov al, byte [random_buffer]
     TAG_INTEGER_REG rax
     ret
.getc_failed:
     xor rax, rax
     TAG_NIL_REG rax
     ret



;; join a character list to a string.
FUNC fn_implode
    mov rbx,rdi
    xor rcx,rcx

.count:
    mov rax,rbx
    GET_TAG_BITS rax
    cmp rax,TAG_ID_NIL
    je .have_len

    ; verify cons
    mov rax,rbx
    GET_TAG_BITS rax
    cmp rax,TAG_ID_CONS
    jne type_error
    inc rcx
    mov rax,rbx
    UNTAG_REG rax
    mov rbx,[rax+8]
    jmp .count

.have_len:
    mov rax,[heap_ptr]
    mov rdx,rcx
    inc rdx
    add [heap_ptr],rdx
    mov r8,rax

    mov rbx,rdi
    xor rcx,rcx
.copy:
    mov rax,rbx
    GET_TAG_BITS rax
    cmp rax,TAG_ID_NIL
    je .finish

    mov rax,rbx
    UNTAG_REG rax
    mov rdx,[rax]
    ; verify char
    mov r9,rdx
    GET_TAG_BITS r9
    cmp r9,TAG_ID_CHAR
    jne type_error
    UNTAG_REG rdx
    mov [r8+rcx],dl
    inc rcx
    mov rbx,[rax+8]
    jmp .copy
.finish:
    mov byte [r8+rcx],0
    mov rax,r8
    TAG_STRING_REG rax
    ret



;; Convert a numeric value to an integer
FUNC fn_int
    mov rax, rdi
    GET_TAG_BITS rax
    cmp rax, TAG_ID_INTEGER
    jz .from_int
    cmp rax, TAG_ID_FLOAT
    jz .from_float
    cmp rax, TAG_ID_CHAR
    jz .from_char
    jmp .return_zero
.from_int:
    mov rax, rdi
    ret
.from_float:
    UNTAG_REG rdi         ; untag
    movq xmm0, [rdi]      ; load
    cvttsd2si rax, xmm0   ; truncate
    TAG_INTEGER_REG rax   ; tag
    ret
.from_char:
    UNTAG_REG rdi
    mov rax, rdi
    TAG_INTEGER_REG rax
    ret
.return_zero:
    xor rax, rax
    TAG_INTEGER_REG rax
    ret


