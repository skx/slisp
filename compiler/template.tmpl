;;; 0. definitions

;; syscalls - searchable list online here
;;  https://filippo.io/linux-syscall-table/

SYS_read        equ 0
SYS_write       equ 1
SYS_open        equ 2
SYS_close       equ 3
SYS_stat        equ 4
SYS_lseek       equ 8
SYS_exit        equ 60
SYS_mkdir       equ 83
SYS_rmdir       equ 84
SYS_unlink      equ 87
SYS_getdents64  equ 217
SYS_getrandom   equ 318


;; (entries)
O_RDONLY        equ 0
O_DIRECTORY     equ 0200000o

;; (stat)
S_IFMT          equ 0170000o
S_IFSOCK        equ 0140000o
S_IFLNK         equ 0120000o
S_IFREG         equ 0100000o
S_IFBLK         equ 0060000o
S_IFDIR         equ 0040000o
S_IFCHR         equ 0020000o
S_IFIFO         equ 0010000o




;;; 1. macros

;;
;; If DEBUG is defined we'll return specific error-codes from
;; our `fread` implementation, which was helpful for debugging.
;;
;; Without it defined we'll just return Nil on all failures which
;; is what we document, and what the user will expect.
;;
%define DEBUG 1
%undef  DEBUG     ;; Comment out this line to enable debugging.

;;
;; We use the lower three bits of values to denote their type,
;; char, cons, float, int, lambda, string, etc.
;;
;; These macros are to be used to tag a register with a given
;; type, or get the type for processing and testing.
;;

; tag a register as an integer
%macro TAG_INTEGER_REG 1
    sal %1, 3
%endmacro

; tag a register as a string
%macro TAG_STRING_REG 1
    sal %1, 3
    or %1, TAG_ID_STRING
%endmacro

; tag a register as a cons pair
%macro TAG_CONS_REG 1
    sal %1, 3
    or %1, TAG_ID_CONS
%endmacro

; tag a register as a lambda
%macro TAG_LAMBDA_REG 1
    sal %1, 3
    or %1, TAG_ID_LAMBDA
%endmacro

; tag a register as a character
%macro TAG_CHAR_REG 1
    sal %1, 3
    or %1, TAG_ID_CHAR
%endmacro

; tag a register as NIL
%macro TAG_NIL_REG 1
    sal %1, 3
    or %1, TAG_ID_NIL
%endmacro

; tag a register as a float
%macro TAG_FLOAT_REG 1
    sal %1, 3
    or %1, TAG_ID_FLOAT
%endmacro

; remove the tag-bits from a register - by shifting right 3 bits.
%macro UNTAG_REG 1
    sar %1, 3
%endmacro

; get the tag bits for the given register.
%macro GET_TAG_BITS 1
    and %1, 7
%endmacro

; The value of the tag-bits we use to denote types.
;
; All the values are chosen "randomly", but int is special because we
; often want to determine if two arguments are *both* integers.  We
; can get the bits and add them like so:
;
;   GET_TAG_BITS rsi
;   GET_TAG_BITS rdi
;   mov rax, rsi
;   add rax, rdi
;   jz  xxxx       -> ZERO?  Both are zero == both are ints
;

TAG_ID_INTEGER equ 0b000  ; 0 - int is special, as noted above.
TAG_ID_STRING  equ 0b001  ; 1
TAG_ID_CONS    equ 0b010  ; 2
TAG_ID_LAMBDA  equ 0b011  ; 3
TAG_ID_CHAR    equ 0b100  ; 4
TAG_ID_FLOAT   equ 0b101  ; 5
TAG_ID_UNUSED  equ 0b110  ; 6 - boolean? error?
TAG_ID_NIL     equ 0b111  ; 7


;;
;; Declare a function which will record itself as having
;; been started.
;;
;; The function will be in its own section, which allows
;; easy dead-code elimination by the linker.
;;
;; We use this for almost all of our standard library,
;; BUT NOT the printing functions, or functions that
;; accept any type.
;;
%macro FUNC 1
    %defstr __fname %1    ; Define a string
    section .rodata       ; Place the string in the RODATA section
%%name:
    db __fname, 0

    section .text.%1,"ax",@progbits  ; Go back to text
    global %1                        ; The function is global
%1:                                  ; Declare the function
    lea rax, [rel %%name]            ; Get the string ptr
    mov [rel last_function], rax     ; save the address in $last_function
%endmacro



