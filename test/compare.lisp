;; Test the comparison operators.
;; They return 1 (int) or NIL depending on whether they are true or not
(defun main ()
      (print "(< 3 4):")
      (print (< 3 4))
      (print " (< 4 4):")
      (print (< 4 4))
      (newline)

      (print "(> 3 4):")
      (print (> 3 4))
      (print " (> 34 4):")
